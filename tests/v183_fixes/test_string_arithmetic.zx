// ========================================================================
// String methods and type conversion tests
// ========================================================================

print("=== String methods ===")

// Basic string operations
let s = "Hello World"
print(s)
print(len(s))

// String concatenation
print("abc" + "def")

// Type conversions
print(string(42))
print(string(3.14))
print(string(true))
print(string(false))
print(string(null))

// Int/Float conversions
print(int("42"))
print(float("3.14"))

// String repetition
print("abc" * 3)

// String comparisons
print("abc" == "abc")
print("abc" != "def")

print("")
print("=== Advanced arithmetic ===")

// Exponentiation
print(2 ** 0)
print(2 ** 1)
print(2 ** 8)
print(3 ** 3)

// Negative exponents
print(10 ** -1)

// Float arithmetic
print(1.5 + 2.5)
print(3.0 - 1.5)
print(2.5 * 4.0)
print(10.0 / 3.0)

// Mixed int/float
print(5 + 2.5)
print(5 - 2.5)
print(5 * 2.5)
print(10 / 2.5)

// Modulo
print(10 % 3)
print(10.5 % 3.0)
print(7 % 2)

print("")
print("STRING AND ARITHMETIC DONE")
